<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="backup_process_ignite_cron" model="ir.cron">
            <field name="name">BV Backup Process Runner</field>
            <field name="model_id" ref="model_backup_process"/>
            <field name="state">code</field>
            <field name="code">model.cron_run_due_backups()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
        </record>

        <record id="backup_file_remove_cron" model="ir.cron">
            <field name="name">BV Backup Retention Cleanup</field>
            <field name="model_id" ref="model_backup_process"/>
            <field name="state">code</field>
            <field name="code">model.cron_remove_old_backups()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
        </record>
    </data>
</odoo>
