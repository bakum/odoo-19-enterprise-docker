<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="backup_remote_server_form_view" model="ir.ui.view">
            <field name="name">backup.remote.server.form</field>
            <field name="model">backup.remote.server</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Reset to Draft" name="reset_to_draft" type="object" class="oe_highlight" invisible="state == 'draft'"/>
                        <button string="Validate" name="set_validated" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" required="1"/>
                                <field name="sftp_host" required="1" readonly="state == 'validated'"/>
                                <field name="sftp_port" required="1" readonly="state == 'validated'"/>
                                <field name="sftp_user" required="1" readonly="state == 'validated'"/>
                                <field name="sftp_password" password="1" required="1" readonly="state == 'validated'"/>
                                <button string="Test Connection" name="test_host_connection" type="object" class="oe_highlight"/>
                            </group>
                            <group>
                                <field name="def_backup_dir" required="1" readonly="state == 'validated'"/>
                                <field name="temp_backup_dir" required="1" readonly="state == 'validated'"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="backup_remote_server_tree_view" model="ir.ui.view">
            <field name="name">backup.remote.server.tree</field>
            <field name="model">backup.remote.server</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="sftp_host"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="backup_remote_server_action_view" model="ir.actions.act_window">
            <field name="name">Backup Remote Servers</field>
            <field name="res_model">backup.remote.server</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
