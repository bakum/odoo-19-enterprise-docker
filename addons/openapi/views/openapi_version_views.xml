<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <menuitem id="menu_api_rest" name="OpenAPI" sequence="100" groups="openapi.configuration_manager" web_icon="openapi,static/description/icon.png"/>

    <record model="ir.ui.view" id="view_api_rest_version_tree">
        <field name="name">api.rest.version.tree</field>
        <field name="model">api.rest.version</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="active"/>
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record model="ir.ui.view" id="view_api_rest_version_form">
        <field name="name">api.rest.version.form</field>
        <field name="model">api.rest.version</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" class="oe_stat_button" icon="fa-globe" name="go_to_api_docs">
                            <div class="o_form_field o_stat_info"><span class="o_stat_text">Go to API Docs</span></div>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Inactive" bg_color="bg-danger" invisible="active==True"/>
                    <group string="API Information">
                        <field name="active" widget="boolean_toggle"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="active_log" widget="boolean_toggle"/>
                        <field name="last_usage_date" readonly="1" invisible="active_log==False"/>
                    </group>
                    <notebook>
                        <page string="Paths">
                            <field name="path_ids" context="{'default_version_id': id}" nolabel="1"/>
                        </page>
                        <page string="Security">
                            <field name="user_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Logs" invisible="active_log==False">
                            <field name="log_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_api_rest_version">
        <field name="name">Versions</field>
        <field name="res_model">api.rest.version</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'active_test': False}</field>
    </record>

    <menuitem id="menu_action_api_rest_version" action="action_api_rest_version" parent="menu_api_rest" sequence="10"/>
</odoo>
