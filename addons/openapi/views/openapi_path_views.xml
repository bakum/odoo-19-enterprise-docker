<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_api_rest_path_tree" model="ir.ui.view">
        <field name="name">api.rest.path.tree</field>
        <field name="model">api.rest.path</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="version_id"/>
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="model_id"/>
                <field name="method"/>
            </list>
        </field>
    </record>

    <record id="view_api_rest_path_form" model="ir.ui.view">
        <field name="name">api.rest.path.form</field>
        <field name="model">api.rest.path</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Inactive" bg_color="bg-danger" invisible="active==True"/>
                    <group>
                        <field name="name"/>
                        <field name="model_id" options="{'no_create': True}"/>
                        <field name="version_id" options="{'no_create': True}"/>
                        <field name="model" invisible="1"/>
                        <field name="description"/>
                        <field name="active" widget="boolean_toggle"/>
                        <field name="deprecated" widget="boolean_toggle"/>
                        <field name="tag_id" options="{'no_create': True}"/>
                        <field name="method" widget="radio"/>
                    </group>
                    <group string="Settings for read" invisible="method not in ['get']">
                        <field name="limit" required="method not in ['get']"/>
                        <field name="filter_domain" widget="domain" options="{'model': 'model', 'in_dialog': True}"/>
                        <field name="field_ids" widget="many2many_tags" required="method == 'get'" options="{'no_create': True}"/>
                    </group>
                    <field name="warning_required" invisible="1"/>
                    <group string="Settings for create/update" invisible="method not in ['post', 'put']">
                        <field name="update_domain" widget="domain" options="{'model': 'model', 'in_dialog': True}" invisible="method not in ['put']"/>
                        <div colspan="2" class="alert alert-danger text-center" role="alert" invisible="warning_required == False">
                            Required fields are missing; create or update may fail.
                        </div>
                        <field name="api_field_ids" context="{'default_path_id': id}">
                            <list editable="bottom" decoration-muted="default_value">
                                <field name="model_id" invisible="1"/>
                                <field name="path_id" invisible="1"/>
                                <field name="sequence" widget="handle"/>
                                <field name="field_id" options="{'no_create': True}"/>
                                <field name="description"/>
                                <field name="default_value"/>
                                <field name="force_required" invisible="1"/>
                                <field name="required" readonly="default_value not in ['', False]"/>
                            </list>
                        </field>
                    </group>
                    <group string="Settings for unlink" invisible="method not in ['delete']">
                        <field name="unlink_domain" widget="domain" options="{'model': 'model', 'in_dialog': True}"/>
                    </group>
                    <group string="Settings for custom function" invisible="method not in ['custom']">
                        <field name="function_apply_on_record" required="method=='custom'"/>
                        <field name="function_domain" widget="domain" options="{'model': 'model', 'in_dialog': True}" invisible="function_apply_on_record==False"/>
                        <field name="function" required="method=='custom'"/>
                        <field name="function_parameter_ids">
                            <list editable="bottom">
                                <field name="path_id" invisible="1"/>
                                <field name="sequence" widget="handle"/>
                                <field name="name"/>
                                <field name="type"/>
                                <field name="description"/>
                                <field name="default_value"/>
                                <field name="required"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_api_rest_path_search" model="ir.ui.view">
        <field name="name">api.rest.path.search</field>
        <field name="model">api.rest.path</field>
        <field name="arch" type="xml">
            <search>
                <filter string="Version" name="groupby_version" domain="[]" context="{'group_by': 'version_id'}"/>
                <filter string="Model" name="groupby_model" domain="[]" context="{'group_by': 'model_id'}"/>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_api_rest_path">
        <field name="name">Paths</field>
        <field name="res_model">api.rest.path</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_api_rest_path_search"/>
        <field name="context">{'search_default_groupby_model': True, 'active_test': False}</field>
    </record>

    <menuitem id="menu_action_api_rest_path" action="action_api_rest_path" parent="menu_api_rest" sequence="20"/>
</odoo>
