<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_openapi_enterprise" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.openapi.enterprise</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="OpenAPI" name="openapi_enterprise" groups="base.group_system">
                    <block title="OpenAPI Security">
                        <setting string="Allowed CORS Origins">
                            <field name="openapi_cors_origins" placeholder="https://app.example.com,https://admin.example.com"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
