<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="backup_gdrive_config_form_view" model="ir.ui.view">
            <field name="name">backup.gdrive.config.form</field>
            <field name="model">backup.gdrive.config</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_get_auth_url" type="object" string="Get Authorization URL" class="oe_highlight"/>
                        <button name="action_fetch_refresh_token" type="object" string="Generate Refresh Token" class="oe_highlight" invisible="not auth_code"/>
                        <button name="test_connection" type="object" string="Test Connection" class="oe_highlight" invisible="not refresh_token"/>
                        <button name="action_open_folder" type="object" string="Open Folder" invisible="not folder_id"/>
                        <button name="reset_to_draft" type="object" string="Reset to Draft" invisible="state == 'draft'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="folder_id"/>
                                <field name="redirect_uri"/>
                            </group>
                            <group>
                                <field name="client_id" password="True"/>
                                <field name="client_secret" password="True"/>
                                <field name="refresh_token" password="True" readonly="1"/>
                            </group>
                        </group>
                        <group string="Token Setup">
                            <field name="auth_code" placeholder="Paste auth code returned by Google"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="backup_gdrive_config_tree_view" model="ir.ui.view">
            <field name="name">backup.gdrive.config.tree</field>
            <field name="model">backup.gdrive.config</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="folder_id"/>
                    <field name="state"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="backup_gdrive_config_action_view" model="ir.actions.act_window">
            <field name="name">Google Drive Configurations</field>
            <field name="res_model">backup.gdrive.config</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
