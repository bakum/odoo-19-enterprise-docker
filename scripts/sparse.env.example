# Copy this file to scripts/sparse.env and adjust values for production.

# Required for initial setup script:
REPO_URL=git@github.com:YOUR_ORG/YOUR_REPO.git

# Optional:
BRANCH=master
TARGET_DIR=/opt/odoo-src
REMOTE_NAME=origin

# One or multiple sparse paths (space-separated), e.g. "addons enterprise"
SPARSE_PATHS=addons
