# Copy this file to scripts/sparse.env and adjust values for production.

# Required for initial setup script:
REPO_URL=https://github.com/bakum/odoo-19-enterprise-docker.git

# Optional:
BRANCH=master
TARGET_DIR=/opt/odoo-src
REMOTE_NAME=origin
SPARSE_MODE=no-cone

# One or multiple sparse paths (space-separated), e.g. "addons enterprise"
SPARSE_PATHS=addons

# SPARSE_MODE options:
# - cone: fast mode, also includes files from repository root
# - no-cone: keep only declared sparse paths (no extra root files)
